      "wpWinPosId": 8,
      "wsWinStyleId": 1
    },
    {
      "tStartMs": 264863,
      "dDurationMs": 1597,
      "segs": [
        {
          "utf8": "-\n팔과 팔꿈치에 약간의 힘을 더 주고"
