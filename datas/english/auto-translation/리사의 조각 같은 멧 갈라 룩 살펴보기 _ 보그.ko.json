    {
      "tStartMs": 341681,
      "dDurationMs": 1960,
      "segs": [
        {
          "utf8": "저 부분을 살펴볼까요?\n- 그녀를 데려올 거예요."
        }
      ],
      "wpWinPosId": 2,
      "wsWinStyleId": 1
    }
