    {
      "tStartMs": 254250,
      "dDurationMs": 2910,
      "segs": [
        {
          "utf8": "생각하기에 마지막으로 하고 싶은 건 치마에도 흰색 메시 소재를\n한 겹 더 추가하는 거예요"
        }
      ],
      "wpWinPosId": 14,
      "wsWinStyleId": 1
    },
    {
      "tStartMs": 257160,
      "dDurationMs": 833,
      "segs": [
        {
          "utf8": ""
        }
      ],
      "wpWinPosId": 7,
      "wsWinStyleId": 1
    },
    {
      "tStartMs": 257993,
      "dDurationMs": 923,
      "segs": [
        {
          "utf8": ".\n- 네, 맞습니다."
