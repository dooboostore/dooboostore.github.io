{
  "wireMagic": "pb3",
  "pens": [
    {}
  ],
  "wsWinStyles": [
    {}
  ],
  "wpWinPositions": [
    {}
  ],
  "events": [
    {
      "tStartMs": 1602,
      "dDurationMs": 1334,
      "segs": [
        {
          "utf8": "-다음 게스트는 에미상 후보에\n오른 배우이자 프로듀서로,"
        }
      ]
    },
    {
      "tStartMs": 2936,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "\n\"완다비전\""
        }
      ]
    },
    {
      "tStartMs": 4571,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "과 마블\n시네마틱 유니버스,"
        }
      ]
    },
    {
      "tStartMs": 6273,
      "dDurationMs": 2035,
      "segs": [
        {
          "utf8": "그리고\n\"윈드 리버\","
        }
      ]
    },
    {
      "tStartMs": 8308,
      "dDurationMs": 2136,
      "segs": [
        {
          "utf8": "\"잉그리드 고즈 웨스트\",\n\"그의 세 딸\" 등의 영화에서 활약하신 분입니다."
        }
      ]
    },
    {
      "tStartMs": 10444,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "그녀는 이번 추수감사절에 전국 극장에서 개봉하는 영화 \"이터니티\"에 출연합니다\n"
        }
      ]
    },
    {
      "tStartMs": 12513,
      "dDurationMs": 1468,
      "segs": [
        {
          "utf8": ".  한번 살펴볼까요?"
        }
      ]
    },
    {
      "tStartMs": 13981,
      "dDurationMs": 1268,
      "segs": [
        {
          "utf8": ""
        }
      ]
    },
    {
      "tStartMs": 16250,
      "dDurationMs": 3203,
      "segs": [
        {
          "utf8": "-어떻게 보이나요?\n-[숨을 헐떡이며]"
        }
      ]
    },
    {
      "tStartMs": 19453,
      "dDurationMs": 2803,
      "segs": [
        {
          "utf8": "그래서, 어쩌라고?\n내가 뭘 해야 하는 거죠?  제가"
        }
      ]
    },
    {
      "tStartMs": 23390,
      "dDurationMs": 2836,
      "segs": [
        {
          "utf8": "\n어떻게 해야 하는지 알려주세요."
        }
      ]
    },
    {
      "tStartMs": 26226,
      "dDurationMs": 2002,
      "segs": [
        {
          "utf8": "-오, 내 사랑.  좋아요."
        }
      ]
    },
    {
      "tStartMs": 28228,
      "dDurationMs": 3937,
      "segs": [
        {
          "utf8": "당신의 이력서를 읽어보니\n똑똑하고 열정적이며 결단력이 뛰어나시군요."
        }
      ]
    },
    {
      "tStartMs": 32165,
      "dDurationMs": 2103,
      "segs": [
        {
          "utf8": "-아, 제가요?  -저는"
        }
      ]
    },
    {
      "tStartMs": 34268,
      "dDurationMs": 2802,
      "segs": [
        {
          "utf8": "\n당신이"
        }
      ]
    },
    {
      "tStartMs": 37070,
      "dDurationMs": 2236,
      "segs": [
        {
          "utf8": "올바른 영원한 삶\n과 그 삶을 함께할 올바른 사람을 선택할 것이라고 전적으로 믿습니다"
        }
      ]
    },
    {
      "tStartMs": 39306,
      "dDurationMs": 1401,
      "segs": [
        {
          "utf8": "."
        }
      ]
    },
    {
      "tStartMs": 40707,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "-[신음] -괜찮을 거야\n."
        }
      ]
    },
    {
      "tStartMs": 42643,
      "dDurationMs": 3370,
      "segs": [
        {
          "utf8": "-무엇을 위해서?\n[문 두드리는 소리] -혹시"
        }
      ]
    },
    {
      "tStartMs": 46013,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "\n누구 기다리셨어요, 아니면…?"
        }
      ]
    },
    {
      "tStartMs": 47648,
      "dDurationMs": 1301,
      "segs": [
        {
          "utf8": "-여러분,\n"
        }
      ]
    },
    {
      "tStartMs": 48949,
      "dDurationMs": 2302,
      "segs": [
        {
          "utf8": "저희 친구 엘리자베스 올슨을 다시 한번 쇼에 환영해 주세요\n."
        }
      ]
    },
    {
      "tStartMs": 51251,
      "dDurationMs": 3871,
      "segs": [
        {
          "utf8": "[환호와 박수]"
        }
      ]
    },
    {
      "tStartMs": 55122,
      "dDurationMs": 9042,
      "segs": [
        {
          "utf8": "♪♪"
        }
      ]
    },
    {
      "tStartMs": 64164,
      "dDurationMs": 6206,
      "segs": [
        {
          "utf8": "♪♪"
        }
      ]
    },
    {
      "tStartMs": 70370,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "안녕하세요.  -\n"
        }
      ]
    },
    {
      "tStartMs": 72439,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "세스, 하이힐에 타이즈를 신어본 적 있어?"
        }
      ]
    },
    {
      "tStartMs": 74141,
      "dDurationMs": 2669,
      "segs": [
        {
          "utf8": "- 저는 해보진 않았지만,\n당신이 움직이는 모습을 보니"
        }
      ]
    },
    {
      "tStartMs": 76810,
      "dDurationMs": 1402,
      "segs": [
        {
          "utf8": "그렇게 쉽지는 않을 것 같네요.\n-힘들었어요.  -"
        }
      ]
    },
    {
      "tStartMs": 78212,
      "dDurationMs": 1267,
      "segs": [
        {
          "utf8": "응.  -\n이미 힘든 상황이에요.  -"
        }
      ]
    },
    {
      "tStartMs": 79479,
      "dDurationMs": 1936,
      "segs": [
        {
          "utf8": "\n내가 왜 스스로에게 그런 짓을 했는지 모르겠어."
        }
      ]
    },
    {
      "tStartMs": 81415,
      "dDurationMs": 3437,
      "segs": [
        {
          "utf8": "\n거기서 여기까지 걸어오는 길이 너무 무서웠어요."
        }
      ]
    },
    {
      "tStartMs": 84852,
      "dDurationMs": 2736,
      "segs": [
        {
          "utf8": "-\n당신의 눈에는 진정한 두려움이 서려 있었어요."
        }
      ]
    },
    {
      "tStartMs": 87588,
      "dDurationMs": 2235,
      "segs": [
        {
          "utf8": "-[웃음] -마치\n"
        }
      ]
    },
    {
      "tStartMs": 89823,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": "\n잠깐 기억상실증에 걸린 것처럼 저를 쳐다보시더라고요. 제가"
        }
      ]
    },
    {
      "tStartMs": 91758,
      "dDurationMs": 2736,
      "segs": [
        {
          "utf8": "누군지,\n이게 뭔지도 모르는 것처럼요."
        }
      ]
    },
    {
      "tStartMs": 94494,
      "dDurationMs": 1268,
      "segs": [
        {
          "utf8": "-나는 길을 잃었어.  -예"
        }
      ]
    },
    {
      "tStartMs": 95762,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": ".  -완전히 길을\n잃었어요.  -네,"
        }
      ]
    },
    {
      "tStartMs": 97664,
      "dDurationMs": 2203,
      "segs": [
        {
          "utf8": "제가 직접 하는 이유는\n다른 사람이 그런 일을 하지 않도록 하기 위해서입니다."
        }
      ]
    },
    {
      "tStartMs": 99867,
      "dDurationMs": 2302,
      "segs": [
        {
          "utf8": "만약\n지금 누군가가 화재경보기를 누른다면,"
        }
      ]
    },
    {
      "tStartMs": 102169,
      "dDurationMs": 2536,
      "segs": [
        {
          "utf8": "당신은 다른 사람들보다 무려\n10분이나 늦게 이곳에서 나갈 수 있을 거예요."
        }
      ]
    },
    {
      "tStartMs": 104705,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "-음, 이걸 벗으면"
        }
      ]
    },
    {
      "tStartMs": 106440,
      "dDurationMs": 1401,
      "segs": [
        {
          "utf8": "\n바닥에서 미끄러질 거예요.  -그러면"
        }
      ]
    },
    {
      "tStartMs": 107841,
      "dDurationMs": 1769,
      "segs": [
        {
          "utf8": "어느 쪽을 선택하든 손해 보는 거죠."
        }
      ]
    },
    {
      "tStartMs": 109610,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": "-저는, 그러니까\n, 저도 굉장히 꼼꼼한 편이라서요--"
        }
      ]
    },
    {
      "tStartMs": 111545,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "괜찮아요, 우린 잘하고 있어요.\n우리는 즐거운 시간을 보내고 있어요.  -"
        }
      ]
    },
    {
      "tStartMs": 113447,
      "dDurationMs": 1501,
      "segs": [
        {
          "utf8": "응!\n-[웃음]"
        }
      ]
    },
    {
      "tStartMs": 114948,
      "dDurationMs": 1936,
      "segs": [
        {
          "utf8": "[환호와 박수] -"
        }
      ]
    },
    {
      "tStartMs": 116884,
      "dDurationMs": 4037,
      "segs": [
        {
          "utf8": "음,\n간단히 축하 인사를 드리고 싶습니다."
        }
      ]
    },
    {
      "tStartMs": 120921,
      "dDurationMs": 1868,
      "segs": [
        {
          "utf8": "제 친구인\n지미 키멜 쇼에서 당신이"
        }
      ]
    },
    {
      "tStartMs": 122789,
      "dDurationMs": 2169,
      "segs": [
        {
          "utf8": "\n다저스의"
        }
      ]
    },
    {
      "tStartMs": 124958,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "월드시리즈 우승에 대해 얼마나 기뻐하는지 이야기하는 걸 봤어요.  -\n응.  -"
        }
      ]
    },
    {
      "tStartMs": 126393,
      "dDurationMs": 1502,
      "segs": [
        {
          "utf8": "축하해요.\n-음, 저는"
        }
      ]
    },
    {
      "tStartMs": 127895,
      "dDurationMs": 2268,
      "segs": [
        {
          "utf8": "그분들을 대신해서 감사 인사를 드린 것 외에는 아무것도 하지 않았습니다.  -천만에요\n, 네."
        }
      ]
    },
    {
      "tStartMs": 130163,
      "dDurationMs": 2336,
      "segs": [
        {
          "utf8": "-음,\n그 시리즈들 정말 재밌었나요?"
        }
      ]
    },
    {
      "tStartMs": 132499,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "-정말\n멋진 시리즈였어요."
        }
      ]
    },
    {
      "tStartMs": 134201,
      "dDurationMs": 2169,
      "segs": [
        {
          "utf8": "\n정말 놀라운 건,"
        }
      ]
    },
    {
      "tStartMs": 136370,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": "당신이"
        }
      ]
    },
    {
      "tStartMs": 138172,
      "dDurationMs": 1901,
      "segs": [
        {
          "utf8": "\n지난 10년 사이에 다저스 팬이 되었다는 점이에요."
        }
      ]
    },
    {
      "tStartMs": 140073,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "그게 정확한가요?  -\n맞습니다.  맞습니다."
        }
      ]
    },
    {
      "tStartMs": 141708,
      "dDurationMs": 1502,
      "segs": [
        {
          "utf8": "-그리고 그 팀은\n네가 유일하게 관심을 갖는 스포츠 팀이지.  -"
        }
      ]
    },
    {
      "tStartMs": 143210,
      "dDurationMs": 1335,
      "segs": [
        {
          "utf8": "맞습니다.  -우와\n.  -"
        }
      ]
    },
    {
      "tStartMs": 144545,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "응.  -당신은 마치\n"
        }
      ]
    },
    {
      "tStartMs": 145913,
      "dDurationMs": 3203,
      "segs": [
        {
          "utf8": "\"나는 금만 좋아해\"라고 말하는 사람 같아요."
        }
      ]
    },
    {
      "tStartMs": 149116,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "-나는 금만 좋아해.\n-네, 한 가지 말씀드릴 게 있어요."
        }
      ]
    },
    {
      "tStartMs": 151185,
      "dDurationMs": 3636,
      "segs": [
        {
          "utf8": "-나는 금만 좋아해.\n다이아몬드는 가져가셔도 됩니다."
        }
      ]
    },
    {
      "tStartMs": 154821,
      "dDurationMs": 2503,
      "segs": [
        {
          "utf8": "은은 네가 가져가도 좋아.\n난 금"
        }
      ]
    },
    {
      "tStartMs": 157324,
      "dDurationMs": 1134,
      "segs": [
        {
          "utf8": "이랑 다저스만 좋아해.  -정말"
        }
      ]
    },
    {
      "tStartMs": 158458,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "좋겠네요.\n"
        }
      ]
    },
    {
      "tStartMs": 159826,
      "dDurationMs": 2470,
      "segs": [
        {
          "utf8": "케이블 뉴스 광고에 출연하실 수 있도록 도와드릴 수 있을 것 같아요.\n마치"
        }
      ]
    },
    {
      "tStartMs": 162296,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "광고 시간 중에 금에 대해 이야기하는 것처럼요.\n-[웃음] -"
        }
      ]
    },
    {
      "tStartMs": 163931,
      "dDurationMs": 2602,
      "segs": [
        {
          "utf8": "음,\n경기 보러 가셨어요?  -네"
        }
      ]
    },
    {
      "tStartMs": 166533,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": ", 저는 그렇게 생각해요.\n나는 ~에 간다. 나는 ~했다.  저는"
        }
      ]
    },
    {
      "tStartMs": 168468,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "포스트시즌 경기를 보러 갔는데,"
        }
      ]
    },
    {
      "tStartMs": 170537,
      "dDurationMs": 2870,
      "segs": [
        {
          "utf8": "\n포스트시즌 경기에 절대 가면 안 되는 이유를 다시 한번 깨달았습니다.  -"
        }
      ]
    },
    {
      "tStartMs": 173407,
      "dDurationMs": 1101,
      "segs": [
        {
          "utf8": "응.  -\n제가"
        }
      ]
    },
    {
      "tStartMs": 174508,
      "dDurationMs": 1068,
      "segs": [
        {
          "utf8": "포스트시즌 경기를 보러 갈 때마다 그들은 항상 졌어요\n.  -"
        }
      ]
    },
    {
      "tStartMs": 175576,
      "dDurationMs": 1868,
      "segs": [
        {
          "utf8": "응.  -음\n, 저는"
        }
      ]
    },
    {
      "tStartMs": 177444,
      "dDurationMs": 1135,
      "segs": [
        {
          "utf8": "브루어스 경기를 보러 갔는데, 그들이 졌어요."
        }
      ]
    },
    {
      "tStartMs": 178579,
      "dDurationMs": 5005,
      "segs": [
        {
          "utf8": "그리고 저는 그들이 2000년에 레드삭스에게 지는 것도 봤어요. 몇 년도였더라\n"
        }
      ]
    },
    {
      "tStartMs": 183584,
      "dDurationMs": 1968,
      "segs": [
        {
          "utf8": "\n?"
        }
      ]
    },
    {
      "tStartMs": 185552,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "2018년 아니면 2019년?  -\n네, 18살이에요."
        }
      ]
    },
    {
      "tStartMs": 187254,
      "dDurationMs": 1835,
      "segs": [
        {
          "utf8": "-네.\n그래서 저는 그때"
        }
      ]
    },
    {
      "tStartMs": 189089,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "다저 스타디움에 있었어요. 제가 거기 있었을 때\n... 아, 그리고 제가 기억하기로"
        }
      ]
    },
    {
      "tStartMs": 190791,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "\n저도 그랬던 것 같아요."
        }
      ]
    },
    {
      "tStartMs": 192159,
      "dDurationMs": 2636,
      "segs": [
        {
          "utf8": "저는 보스턴 레드삭스 팬입니다.\n그리고 2004년에 저는 --"
        }
      ]
    },
    {
      "tStartMs": 194795,
      "dDurationMs": 2169,
      "segs": [
        {
          "utf8": "[환호와 박수]\n감사합니다.  여러분 모두 감사합니다."
        }
      ]
    },
    {
      "tStartMs": 196964,
      "dDurationMs": 2435,
      "segs": [
        {
          "utf8": "음, 보세요?\n축하를 받아들이겠습니다.  -늦었지만"
        }
      ]
    },
    {
      "tStartMs": 199399,
      "dDurationMs": 2803,
      "segs": [
        {
          "utf8": ",\n제가 응원했던 분의 우승을 진심으로 축하드립니다.  -"
        }
      ]
    },
    {
      "tStartMs": 202202,
      "dDurationMs": 1468,
      "segs": [
        {
          "utf8": "매우 감사합니다.\n네, 네, 감사합니다."
        }
      ]
    },
    {
      "tStartMs": 203670,
      "dDurationMs": 1302,
      "segs": [
        {
          "utf8": "\n그날 밤 해주신 모든 일에 감사드립니다."
        }
      ]
    },
    {
      "tStartMs": 204972,
      "dDurationMs": 1067,
      "segs": [
        {
          "utf8": "-[웃음] -네\n, 거기서 봤어요."
        }
      ]
    },
    {
      "tStartMs": 206039,
      "dDurationMs": 2436,
      "segs": [
        {
          "utf8": "우리는 \"우리에게 기회가 왔어\"라고 생각했죠.  -\n응."
        }
      ]
    },
    {
      "tStartMs": 208475,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "-하지만 저는"
        }
      ]
    },
    {
      "tStartMs": 210110,
      "dDurationMs": 1502,
      "segs": [
        {
          "utf8": "레드삭스가\n양키스에게 졌던 경기만 보러 갔었어요.  저는"
        }
      ]
    },
    {
      "tStartMs": 211612,
      "dDurationMs": 1401,
      "segs": [
        {
          "utf8": "아마 세 경기를 연달아 보러 갔던 것 같아요.\n"
        }
      ]
    },
    {
      "tStartMs": 213013,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "\n유명한"
        }
      ]
    },
    {
      "tStartMs": 214748,
      "dDurationMs": 2102,
      "segs": [
        {
          "utf8": "아메리칸 리그\n챔피언십 시리즈 4차전 티켓도 있었는데, '"
        }
      ]
    },
    {
      "tStartMs": 216850,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": "\n"
        }
      ]
    },
    {
      "tStartMs": 218652,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "내가 문제였구나' 싶어서 티켓을 다른 사람에게 줘버렸어요.\n-오른쪽.  -그런데 그"
        }
      ]
    },
    {
      "tStartMs": 220254,
      "dDurationMs": 2035,
      "segs": [
        {
          "utf8": "후로 우리는\n여덟 경기를 모두 이겼는데,"
        }
      ]
    },
    {
      "tStartMs": 222289,
      "dDurationMs": 2636,
      "segs": [
        {
          "utf8": "\n아직 아무도 제게 기념패를 주지 않았어요."
        }
      ]
    },
    {
      "tStartMs": 224925,
      "dDurationMs": 1835,
      "segs": [
        {
          "utf8": "-오른쪽.\n그건 모두 당신 덕분이에요.  -"
        }
      ]
    },
    {
      "tStartMs": 226760,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "당연히 내 탓이지.  -\n응."
        }
      ]
    },
    {
      "tStartMs": 228195,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "제 말은, 저도\n그 의견에 동의한다는 뜻입니다.  -감사합니다"
        }
      ]
    },
    {
      "tStartMs": 229563,
      "dDurationMs": 1468,
      "segs": [
        {
          "utf8": ".  -\n"
        }
      ]
    },
    {
      "tStartMs": 231031,
      "dDurationMs": 1134,
      "segs": [
        {
          "utf8": "이런\n경기 후 인터뷰에는 가지 않는 게 좋을 것 같아요."
        }
      ]
    },
    {
      "tStartMs": 232165,
      "dDurationMs": 1202,
      "segs": [
        {
          "utf8": "-그리고, 한 가지 더 말씀드려도 될까요\n?"
        }
      ]
    },
    {
      "tStartMs": 233367,
      "dDurationMs": 1301,
      "segs": [
        {
          "utf8": "경기들이\n너무 늦게 시작해서,"
        }
      ]
    },
    {
      "tStartMs": 234668,
      "dDurationMs": 3170,
      "segs": [
        {
          "utf8": "저희는 이제 자야 해요.  -저는"
        }
      ]
    },
    {
      "tStartMs": 237838,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "서부 시간대를 보고 있어요."
        }
      ]
    },
    {
      "tStartMs": 239473,
      "dDurationMs": 1301,
      "segs": [
        {
          "utf8": "-아, 맞아요.\n-네, 저는 괜찮아요."
        }
      ]
    },
    {
      "tStartMs": 240774,
      "dDurationMs": 2669,
      "segs": [
        {
          "utf8": "-이건... 솔직히 말해서,\n"
        }
      ]
    },
    {
      "tStartMs": 243443,
      "dDurationMs": 2203,
      "segs": [
        {
          "utf8": "동부 해안 사람들에게 이번 월드 시리즈는 정말 잔혹했어요.\n-정말 끔찍했어요."
        }
      ]
    },
    {
      "tStartMs": 245646,
      "dDurationMs": 2936,
      "segs": [
        {
          "utf8": "그리고 저는 경기 후에 이어지는 두 시간짜리\n경기 후 프로그램도 좋아합니다."
        }
      ]
    },
    {
      "tStartMs": 248582,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": "\n제가 스펙트럼을 구독하고 있어서 그 프로그램이"
        }
      ]
    },
    {
      "tStartMs": 250384,
      "dDurationMs": 2169,
      "segs": [
        {
          "utf8": "\n완전히 별개의 콘텐츠처럼 느껴지거든요."
        }
      ]
    },
    {
      "tStartMs": 252553,
      "dDurationMs": 3069,
      "segs": [
        {
          "utf8": "예를 들어,\n폭스 채널에서 폭스 스포츠 채널(이름이 정확히 기억나지 않지만)로 바꾸고 나서"
        }
      ]
    },
    {
      "tStartMs": 255622,
      "dDurationMs": 1402,
      "segs": [
        {
          "utf8": "\n"
        }
      ]
    },
    {
      "tStartMs": 257024,
      "dDurationMs": 1535,
      "segs": [
        {
          "utf8": "스펙트럼 채널로 가는 거죠.  -그러니까"
        }
      ]
    },
    {
      "tStartMs": 258559,
      "dDurationMs": 3036,
      "segs": [
        {
          "utf8": "당신은\n경기 후 분석 영상을 보는 걸 좋아하는 거군요?  -예"
        }
      ]
    },
    {
      "tStartMs": 261595,
      "dDurationMs": 1535,
      "segs": [
        {
          "utf8": ".  -우와\n."
        }
      ]
    },
    {
      "tStartMs": 263130,
      "dDurationMs": 1401,
      "segs": [
        {
          "utf8": "-음, 특히\n스펙트럼의 경우,"
        }
      ]
    },
    {
      "tStartMs": 264531,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "\n데이비드 바세그라는 사람이 출연자"
        }
      ]
    },
    {
      "tStartMs": 266166,
      "dDurationMs": 3070,
      "segs": [
        {
          "utf8": "들을 인터뷰하는데,\n그는 친절해요. 출연자들은 그를"
        }
      ]
    },
    {
      "tStartMs": 269236,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "좋아하는데...\n그들이 그를 괴롭히는 건지 아닌지는 잘 모르겠네요."
        }
      ]
    },
    {
      "tStartMs": 271138,
      "dDurationMs": 2736,
      "segs": [
        {
          "utf8": "-좋아요.  -\n어, 하지만 그는 굉장히 재밌어요."
        }
      ]
    },
    {
      "tStartMs": 273874,
      "dDurationMs": 2135,
      "segs": [
        {
          "utf8": "그런데 저는\n"
        }
      ]
    },
    {
      "tStartMs": 276009,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "그들이 그와 어떤 관계인지 잘 모르겠어요.\n알 수가 없네요.  -그러니까"
        }
      ]
    },
    {
      "tStartMs": 277744,
      "dDurationMs": 2269,
      "segs": [
        {
          "utf8": "\n스포츠 자체보다는 그 안에서 벌어지는"
        }
      ]
    },
    {
      "tStartMs": 280013,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "인간관계에 더 초점을 맞춰서 경기를 보시는 거군요\n?  -예"
        }
      ]
    },
    {
      "tStartMs": 281448,
      "dDurationMs": 1668,
      "segs": [
        {
          "utf8": ".  제가 축구를 못하는 이유가 바로 그거예요. 축구 선수\n"
        }
      ]
    },
    {
      "tStartMs": 283116,
      "dDurationMs": 1869,
      "segs": [
        {
          "utf8": "들은 모두\n얼굴에 보호대를 끼고 있잖아요."
        }
      ]
    },
    {
      "tStartMs": 284985,
      "dDurationMs": 2236,
      "segs": [
        {
          "utf8": "-오, 당신, 당신이\n얼굴을 볼 수 없다면,"
        }
      ]
    },
    {
      "tStartMs": 287221,
      "dDurationMs": 1768,
      "segs": [
        {
          "utf8": "관심 없어요.  -저는 --네\n."
        }
      ]
    },
    {
      "tStartMs": 288989,
      "dDurationMs": 1068,
      "segs": [
        {
          "utf8": "저는 등장인물들에게 몰입했어요.  -좋아요"
        }
      ]
    },
    {
      "tStartMs": 290057,
      "dDurationMs": 2502,
      "segs": [
        {
          "utf8": ", 잘됐네요.  -\n응."
        }
      ]
    },
    {
      "tStartMs": 292559,
      "dDurationMs": 1969,
      "segs": [
        {
          "utf8": "[웃음] -당신의 영화에"
        }
      ]
    },
    {
      "tStartMs": 294528,
      "dDurationMs": 1968,
      "segs": [
        {
          "utf8": "대해 이야기하고 싶어요\n."
        }
      ]
    },
    {
      "tStartMs": 296496,
      "dDurationMs": 1402,
      "segs": [
        {
          "utf8": "-그것은 \"영원\"이라고 불립니다.  -\n미안해, \"이터니티\"."
        }
      ]
    },
    {
      "tStartMs": 297898,
      "dDurationMs": 2002,
      "segs": [
        {
          "utf8": "-네, 네.  -하지만\n"
        }
      ]
    },
    {
      "tStartMs": 299900,
      "dDurationMs": 2369,
      "segs": [
        {
          "utf8": "제 생각엔 판타지\n로맨틱 코미디 장르인 것 같아요."
        }
      ]
    },
    {
      "tStartMs": 302269,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "\n그게 정확하다고 생각하세요?  -네"
        }
      ]
    },
    {
      "tStartMs": 303871,
      "dDurationMs": 2135,
      "segs": [
        {
          "utf8": ", 사후 세계를 배경으로 한 로맨틱 코미디예요\n."
        }
      ]
    },
    {
      "tStartMs": 306006,
      "dDurationMs": 2269,
      "segs": [
        {
          "utf8": "그래서 상황에 따라 다릅니다.\n사후 세계는 환상일까요?  -"
        }
      ]
    },
    {
      "tStartMs": 308275,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "응.\n저는 그것을 보게 되어 기뻤습니다.  저는"
        }
      ]
    },
    {
      "tStartMs": 309710,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "요즘 시대에"
        }
      ]
    },
    {
      "tStartMs": 311445,
      "dDurationMs": 1535,
      "segs": [
        {
          "utf8": "\n"
        }
      ]
    },
    {
      "tStartMs": 312980,
      "dDurationMs": 3803,
      "segs": [
        {
          "utf8": "\n사후 세계가 있다는 걸 아는 게 좋다고 생각해요. 정말 즐거웠고, 기분이 좋았어요."
        }
      ]
    },
    {
      "tStartMs": 316783,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "나는\n\"아, 이거라면 잘 되겠는데?\"라고 생각했다.  -"
        }
      ]
    },
    {
      "tStartMs": 318385,
      "dDurationMs": 2102,
      "segs": [
        {
          "utf8": "이거 마음에 드세요?  -\n응.  이유를 아시잖아요?"
        }
      ]
    },
    {
      "tStartMs": 320487,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "곧바로 관료주의적인\n헛소리가 시작됩니다.  -예"
        }
      ]
    },
    {
      "tStartMs": 322189,
      "dDurationMs": 2436,
      "segs": [
        {
          "utf8": ".  절차가 복잡하고 관료주의적입니다\n."
        }
      ]
    },
    {
      "tStartMs": 324625,
      "dDurationMs": 2002,
      "segs": [
        {
          "utf8": "그리고 당신은 그걸 좋아하죠.  -그렇다면\n기쁠 것 같아요.  나는"
        }
      ]
    },
    {
      "tStartMs": 326627,
      "dDurationMs": 1468,
      "segs": [
        {
          "utf8": "\"아, 다행이네. 별로 다르지 않겠구나\n.\"라고 생각할 것 같아.  -"
        }
      ]
    },
    {
      "tStartMs": 328095,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "아니요, 너무 관료적이에요."
        }
      ]
    },
    {
      "tStartMs": 329530,
      "dDurationMs": 1868,
      "segs": [
        {
          "utf8": "\n오늘날 우리의 문화와 매우 유사합니다.  -"
        }
      ]
    },
    {
      "tStartMs": 331398,
      "dDurationMs": 1101,
      "segs": [
        {
          "utf8": "응.  -우리는\n"
        }
      ]
    },
    {
      "tStartMs": 332499,
      "dDurationMs": 2336,
      "segs": [
        {
          "utf8": "사람들에게 소비주의를 강요하고 있을 뿐입니다.  -\n응.  - 마치..."
        }
      ]
    },
    {
      "tStartMs": 334835,
      "dDurationMs": 2969,
      "segs": [
        {
          "utf8": "확실히\n자본주의적인 사후 세계 같아요.  -그러면"
        }
      ]
    },
    {
      "tStartMs": 337804,
      "dDurationMs": 1969,
      "segs": [
        {
          "utf8": "곧바로\n사후세계에 나타나서"
        }
      ]
    },
    {
      "tStartMs": 339773,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "\n우리 모두가 절대 하고 싶어 하지 않는 일,"
        }
      ]
    },
    {
      "tStartMs": 341842,
      "dDurationMs": 1401,
      "segs": [
        {
          "utf8": "즉 결정을 내려야 하죠."
        }
      ]
    },
    {
      "tStartMs": 343243,
      "dDurationMs": 2102,
      "segs": [
        {
          "utf8": "-네, 그리고 모두가\n"
        }
      ]
    },
    {
      "tStartMs": 345345,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": "일주일 동안, 영원히, 남은\n평생 동안 어떤 결정을 아주 빨리 내려야만 하죠."
        }
      ]
    },
    {
      "tStartMs": 347147,
      "dDurationMs": 1502,
      "segs": [
        {
          "utf8": "-그리고 그들은 그것을 바꿀 수 없고, 그대로 받아들여야 합니다\n.  -네"
        }
      ]
    },
    {
      "tStartMs": 348649,
      "dDurationMs": 2502,
      "segs": [
        {
          "utf8": ", 그리고\n그들이 할 수 있는 일은 더 이상 없어요.  -당신은 이 역할이"
        }
      ]
    },
    {
      "tStartMs": 351151,
      "dDurationMs": 2102,
      "segs": [
        {
          "utf8": "\n"
        }
      ]
    },
    {
      "tStartMs": 353253,
      "dDurationMs": 1835,
      "segs": [
        {
          "utf8": "당신에게 꿈의 역할이라고 말하는 걸 들었어요.  -\n응."
        }
      ]
    },
    {
      "tStartMs": 355088,
      "dDurationMs": 2536,
      "segs": [
        {
          "utf8": "-하지만 그게\n사실인 데에는 아주 구체적인 이유가 있습니다."
        }
      ]
    },
    {
      "tStartMs": 357624,
      "dDurationMs": 3137,
      "segs": [
        {
          "utf8": "-네, 왜냐하면 저는\n죽었다"
        }
      ]
    },
    {
      "tStartMs": 360761,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": "가 사후 세계에서\n이 몸으로 깨어나는 90세 여성을 연기하기 때문입니다.  -"
        }
      ]
    },
    {
      "tStartMs": 362696,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "응.\n-그리고 아시다시피,"
        }
      ]
    },
    {
      "tStartMs": 364131,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "로맨틱 코미디를 찍을 때 보통 주연 배우는"
        }
      ]
    },
    {
      "tStartMs": 366033,
      "dDurationMs": 3436,
      "segs": [
        {
          "utf8": "\n성적으로 매력적이어야 한다고 생각해요."
        }
      ]
    },
    {
      "tStartMs": 369469,
      "dDurationMs": 2002,
      "segs": [
        {
          "utf8": "그리고 뭔가\n정말 좋은 점이 있는데... -"
        }
      ]
    },
    {
      "tStartMs": 371471,
      "dDurationMs": 3104,
      "segs": [
        {
          "utf8": "저한테는 해당되지 않네요.\n그건 옳지 않아요."
        }
      ]
    },
    {
      "tStartMs": 374575,
      "dDurationMs": 1901,
      "segs": [
        {
          "utf8": "저는 사랑과는\n아무런 관련이 없다고 생각합니다."
        }
      ]
    },
    {
      "tStartMs": 376476,
      "dDurationMs": 2770,
      "segs": [
        {
          "utf8": "-[웃음] 네, 당신은 그런 데에는\n관심이 없으시군요.  -"
        }
      ]
    },
    {
      "tStartMs": 379246,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "사실\n저는 돈을 주고 90세 노인"
        }
      ]
    },
    {
      "tStartMs": 380848,
      "dDurationMs": 1801,
      "segs": [
        {
          "utf8": "배우들을 섭외해서\n\"프리티 우먼\"을 리메이크하게 했어요"
        }
      ]
    },
    {
      "tStartMs": 382649,
      "dDurationMs": 2236,
      "segs": [
        {
          "utf8": "."
        }
      ]
    },
    {
      "tStartMs": 384885,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": "-하지만 그게 얼마나 흥미로울까요\n?  -정말 좋았어요."
        }
      ]
    },
    {
      "tStartMs": 386820,
      "dDurationMs": 2269,
      "segs": [
        {
          "utf8": "\nVHS 테이프 드릴게요."
        }
      ]
    },
    {
      "tStartMs": 389089,
      "dDurationMs": 2202,
      "segs": [
        {
          "utf8": "[웃음] -"
        }
      ]
    },
    {
      "tStartMs": 391291,
      "dDurationMs": 1569,
      "segs": [
        {
          "utf8": "아, 그때 성공하셨군요."
        }
      ]
    },
    {
      "tStartMs": 392860,
      "dDurationMs": 1868,
      "segs": [
        {
          "utf8": "-그래, 그래, 그래.\n-음, 네."
        }
      ]
    },
    {
      "tStartMs": 394728,
      "dDurationMs": 2136,
      "segs": [
        {
          "utf8": "그러니까,\n뭔가 정말 색다른 걸 경험해볼 기회가 있었는데"
        }
      ]
    },
    {
      "tStartMs": 396864,
      "dDurationMs": 3103,
      "segs": [
        {
          "utf8": ",\n제가 마치 할머니가 된 것 같은 기분이 들어요."
        }
      ]
    },
    {
      "tStartMs": 399967,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": "-실생활에서.  -\n응.  -"
        }
      ]
    },
    {
      "tStartMs": 401902,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "오래된 영혼.  -그렇지는 않아요\n.  제가"
        }
      ]
    },
    {
      "tStartMs": 403504,
      "dDurationMs": 3069,
      "segs": [
        {
          "utf8": "\n시대의 흐름에 조금 뒤처진 것 같다는 생각이 들어요."
        }
      ]
    },
    {
      "tStartMs": 406573,
      "dDurationMs": 1502,
      "segs": [
        {
          "utf8": "-좋아요.\n항상 이런 느낌이었나요?  -"
        }
      ]
    },
    {
      "tStartMs": 408075,
      "dDurationMs": 1501,
      "segs": [
        {
          "utf8": "응.\n-좋아요."
        }
      ]
    },
    {
      "tStartMs": 409576,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "그래서 대학에 가서도\n"
        }
      ]
    },
    {
      "tStartMs": 411178,
      "dDurationMs": 2703,
      "segs": [
        {
          "utf8": "친구들이\n\"쟤는"
        }
      ]
    },
    {
      "tStartMs": 413881,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "시대에 뒤떨어졌어\"라고 말할 것 같은 느낌이 들곤 했죠.  -예\n.  저는 요즘"
        }
      ]
    },
    {
      "tStartMs": 415516,
      "dDurationMs": 1134,
      "segs": [
        {
          "utf8": "\n문화계에서 무슨 일이 벌어지고 있는지 잘 모르겠어요."
        }
      ]
    },
    {
      "tStartMs": 416650,
      "dDurationMs": 1034,
      "segs": [
        {
          "utf8": "-알았어.  -\n응."
        }
      ]
    },
    {
      "tStartMs": 417684,
      "dDurationMs": 2036,
      "segs": [
        {
          "utf8": "음, 하지만 저는 67에 대해서는 알고 있어요."
        }
      ]
    },
    {
      "tStartMs": 419720,
      "dDurationMs": 2369,
      "segs": [
        {
          "utf8": "-오, 축하해요"
        }
      ]
    },
    {
      "tStartMs": 422089,
      "dDurationMs": 1968,
      "segs": [
        {
          "utf8": ".  -제\n생각에는... 감사합니다."
        }
      ]
    },
    {
      "tStartMs": 424057,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "저는 67이라는 숫자에 정말 관심이 많아요. -흥미"
        }
      ]
    },
    {
      "tStartMs": 425659,
      "dDurationMs": 1335,
      "segs": [
        {
          "utf8": "롭네요.  -\n응.  -이제는 제"
        }
      ]
    },
    {
      "tStartMs": 426994,
      "dDurationMs": 1868,
      "segs": [
        {
          "utf8": "아이들도 그렇게 말해요.  -\n응.  -그리고"
        }
      ]
    },
    {
      "tStartMs": 428862,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "저는\n"
        }
      ]
    },
    {
      "tStartMs": 430931,
      "dDurationMs": 3036,
      "segs": [
        {
          "utf8": "후속 질문을 하지 않기로 적극적으로 결정했습니다.\n-좋아요.  제가"
        }
      ]
    },
    {
      "tStartMs": 433967,
      "dDurationMs": 1268,
      "segs": [
        {
          "utf8": "설명해 드릴 수 있습니다.  -한번 해보"
        }
      ]
    },
    {
      "tStartMs": 435235,
      "dDurationMs": 1468,
      "segs": [
        {
          "utf8": "시겠어요?  -\n응."
        }
      ]
    },
    {
      "tStartMs": 436703,
      "dDurationMs": 1168,
      "segs": [
        {
          "utf8": "이건\nExplain It Now에 있는 내용인 것 같아요."
        }
      ]
    },
    {
      "tStartMs": 437871,
      "dDurationMs": 2303,
      "segs": [
        {
          "utf8": "-이건 이제 공식 기록으로 남았으니\n참고하세요."
        }
      ]
    },
    {
      "tStartMs": 440174,
      "dDurationMs": 1768,
      "segs": [
        {
          "utf8": "-제 생각에\n사람들이 그걸 좋아하는 이유는 그게"
        }
      ]
    },
    {
      "tStartMs": 441942,
      "dDurationMs": 1868,
      "segs": [
        {
          "utf8": "\n황당하고 예측 불가능하기 때문인 것 같아요.  -"
        }
      ]
    },
    {
      "tStartMs": 443810,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "응.  -\n정말 훌륭하네요.  -"
        }
      ]
    },
    {
      "tStartMs": 445712,
      "dDurationMs": 1535,
      "segs": [
        {
          "utf8": "응.\n-음, 제 생각엔 우리가 정말"
        }
      ]
    },
    {
      "tStartMs": 447247,
      "dDurationMs": 2670,
      "segs": [
        {
          "utf8": "많은 일들을 하고 있는 것 같은데,\n음, 뭐라고 해야 할까요,"
        }
      ]
    },
    {
      "tStartMs": 449917,
      "dDurationMs": 2802,
      "segs": [
        {
          "utf8": "어쩌면 냉소적이거나\n뭔가를 암시하는 것 같기도 해요."
        }
      ]
    },
    {
      "tStartMs": 452719,
      "dDurationMs": 2670,
      "segs": [
        {
          "utf8": "그리고 단순히 순서대로 나열된 두 숫자에 흥분한다는 그 추상적이고 부조리한 모습이\n제게는 정말 재밌게 느껴져요"
        }
      ]
    },
    {
      "tStartMs": 455389,
      "dDurationMs": 4504,
      "segs": [
        {
          "utf8": "\n"
        }
      ]
    },
    {
      "tStartMs": 459893,
      "dDurationMs": 2770,
      "segs": [
        {
          "utf8": "\n.  -"
        }
      ]
    },
    {
      "tStartMs": 462663,
      "dDurationMs": 2536,
      "segs": [
        {
          "utf8": "응.  저 순서대로 나열된 건\n훨씬 더 황당해."
        }
      ]
    },
    {
      "tStartMs": 465199,
      "dDurationMs": 1001,
      "segs": [
        {
          "utf8": "그건 마치... 마치 여섯 살이 됐다가\n"
        }
      ]
    },
    {
      "tStartMs": 466200,
      "dDurationMs": 1701,
      "segs": [
        {
          "utf8": "일곱 살이 되는 사람은 아무도 없는 것처럼 말이죠.  \"그게"
        }
      ]
    },
    {
      "tStartMs": 467901,
      "dDurationMs": 1669,
      "segs": [
        {
          "utf8": "\n그들이 한 전부야?\"라고 생각하게 되죠.  -"
        }
      ]
    },
    {
      "tStartMs": 469570,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "응.\n그건... 그건..."
        }
      ]
    },
    {
      "tStartMs": 471205,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "\n이상한 조합 같은 게 아니에요.  -아니요"
        }
      ]
    },
    {
      "tStartMs": 472940,
      "dDurationMs": 1201,
      "segs": [
        {
          "utf8": ".  -예전과 똑같아요\n"
        }
      ]
    },
    {
      "tStartMs": 474141,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": ".  -\n정말 훌륭해요."
        }
      ]
    },
    {
      "tStartMs": 475943,
      "dDurationMs": 3470,
      "segs": [
        {
          "utf8": "하지만 제가\n아들들에게 주는 선물은, 마치"
        }
      ]
    },
    {
      "tStartMs": 479413,
      "dDurationMs": 2335,
      "segs": [
        {
          "utf8": "\n그 일에 완전히 넋을 잃고 놀라는 것 같은 기분을 느끼게 해주는 것 같아요."
        }
      ]
    },
    {
      "tStartMs": 481748,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "-오른쪽.  -\n왜냐하면, 제 생각엔"
        }
      ]
    },
    {
      "tStartMs": 483483,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "그들의 기쁨이, 음,\n저는 잘 이해가 안 가거든요."
        }
      ]
    },
    {
      "tStartMs": 485118,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "-오른쪽.\n그게 바로 그들이 좋아하는 거예요.  -그래서"
        }
      ]
    },
    {
      "tStartMs": 487187,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "저는 항상\n\"이게 뭐지?\"라고 생각해요."
        }
      ]
    },
    {
      "tStartMs": 488555,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "그러면 그들은 \"[웃음]\"이라고 하죠.\n맞아요.  더 이상 할 말이 없네요"
        }
      ]
    },
    {
      "tStartMs": 490457,
      "dDurationMs": 1535,
      "segs": [
        {
          "utf8": "."
        }
      ]
    },
    {
      "tStartMs": 491992,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "-네, 딱히 할 말이 없네요.\n그들은 설명할 수 없어요.  - 다만"
        }
      ]
    },
    {
      "tStartMs": 493694,
      "dDurationMs": 2602,
      "segs": [
        {
          "utf8": "다른 사람이\n그렇게 어리둥절해하는 모습을 보는 건 빼고요."
        }
      ]
    },
    {
      "tStartMs": 496296,
      "dDurationMs": 2403,
      "segs": [
        {
          "utf8": "-네, 그게 바로 기쁨이죠.\n저는 아주... 우리가 '"
        }
      ]
    },
    {
      "tStartMs": 498699,
      "dDurationMs": 2569,
      "segs": [
        {
          "utf8": "\n오래된 영혼'에 대해 이야기하는 것처럼, 제 역할에 점점 더 익숙해지고 있어요."
        }
      ]
    },
    {
      "tStartMs": 501268,
      "dDurationMs": 2402,
      "segs": [
        {
          "utf8": "지금 제 역할은\n집에 있으면서 세상에서 제일"
        }
      ]
    },
    {
      "tStartMs": 503670,
      "dDurationMs": 2570,
      "segs": [
        {
          "utf8": "멍청한 놈이 되는 거죠\n..."
        }
      ]
    },
    {
      "tStartMs": 506240,
      "dDurationMs": 1067,
      "segs": [
        {
          "utf8": "[웃음]"
        }
      ]
    },
    {
      "tStartMs": 507307,
      "dDurationMs": 1168,
      "segs": [
        {
          "utf8": "말 그대로,"
        }
      ]
    },
    {
      "tStartMs": 508475,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "그게\n우리 가족 모두에게 필요한 거예요."
        }
      ]
    },
    {
      "tStartMs": 510377,
      "dDurationMs": 2202,
      "segs": [
        {
          "utf8": "그들은 마치 \"저 바보 좀 봐,\n아무것도 이해 못 하잖아\"라고 말하는 것 같아요.  -전에"
        }
      ]
    },
    {
      "tStartMs": 512579,
      "dDurationMs": 2836,
      "segs": [
        {
          "utf8": "\n당신이 진행했던 스페셜 방송 중 하나에서"
        }
      ]
    },
    {
      "tStartMs": 515415,
      "dDurationMs": 2269,
      "segs": [
        {
          "utf8": "\n게임을 하다가 게임 구성품"
        }
      ]
    },
    {
      "tStartMs": 517684,
      "dDurationMs": 2870,
      "segs": [
        {
          "utf8": "의 일부가 그\n아래로 들어가는 장면이 생각나네요."
        }
      ]
    },
    {
      "tStartMs": 520554,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "-그들은 할 수 없어 -- -\n가구 한 점.  -그들은"
        }
      ]
    },
    {
      "tStartMs": 522189,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "주사위를\n테이블 위에 제대로 놓아두지 못해요.  -"
        }
      ]
    },
    {
      "tStartMs": 523557,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "응.\n-그러니까 네가 제일 좋아하는"
        }
      ]
    },
    {
      "tStartMs": 525459,
      "dDurationMs": 1968,
      "segs": [
        {
          "utf8": "순간은 숨을 수 있을 때인 것 같네.  -\n응.  나는 주사위를 찾으려고"
        }
      ]
    },
    {
      "tStartMs": 527427,
      "dDurationMs": 1869,
      "segs": [
        {
          "utf8": "소파 밑으로 기어들어가면 그냥\n"
        }
      ]
    },
    {
      "tStartMs": 529296,
      "dDurationMs": 1335,
      "segs": [
        {
          "utf8": "거기 가만히 있어.  -그건"
        }
      ]
    },
    {
      "tStartMs": 530631,
      "dDurationMs": 2135,
      "segs": [
        {
          "utf8": "정말...\n정말 제게 깊은 인상을 남겼어요."
        }
      ]
    },
    {
      "tStartMs": 532766,
      "dDurationMs": 1602,
      "segs": [
        {
          "utf8": "-정말 좋네요.  제 말을\n믿으세요."
        }
      ]
    },
    {
      "tStartMs": 534368,
      "dDurationMs": 1268,
      "segs": [
        {
          "utf8": "어느 순간 이런 생각이 들어요.\n"
        }
      ]
    },
    {
      "tStartMs": 535636,
      "dDurationMs": 1234,
      "segs": [
        {
          "utf8": "여기가 바로 내가 있을 수 있는 유일한 곳이야. 아무도 \"\n"
        }
      ]
    },
    {
      "tStartMs": 536870,
      "dDurationMs": 1869,
      "segs": [
        {
          "utf8": "\n뭐야?"
        }
      ]
    },
    {
      "tStartMs": 538739,
      "dDurationMs": 1601,
      "segs": [
        {
          "utf8": "\"라고 묻지 않는 곳이지. 왜냐하면 난\n마치 그들을 위해 봉사하는 척하지만,"
        }
      ]
    },
    {
      "tStartMs": 540340,
      "dDurationMs": 3170,
      "segs": [
        {
          "utf8": "사실은 그냥 쉬고 있는 거니까.  -\n응.  [웃음] -혹시"
        }
      ]
    },
    {
      "tStartMs": 543510,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": "특별히\n오래된 습관 같은 게 있으신가요?"
        }
      ]
    },
    {
      "tStartMs": 545312,
      "dDurationMs": 1702,
      "segs": [
        {
          "utf8": "\n친구들이 \""
        }
      ]
    },
    {
      "tStartMs": 547014,
      "dDurationMs": 2002,
      "segs": [
        {
          "utf8": "이건\n엘리자베스의 가장... 특이한 모습이네\"라고 말할 것 같다는 생각이 드세요?"
        }
      ]
    },
    {
      "tStartMs": 549016,
      "dDurationMs": 2569,
      "segs": [
        {
          "utf8": "음, 그러니까, 그게 어떤\n특성인지"
        }
      ]
    },
    {
      "tStartMs": 551585,
      "dDurationMs": 1935,
      "segs": [
        {
          "utf8": "아니면 그냥\n전반적인 모습인지 잘 모르겠어요."
        }
      ]
    },
    {
      "tStartMs": 553520,
      "dDurationMs": 2536,
      "segs": [
        {
          "utf8": "저는 문자를 주고받을 때 문장 끝에\n마침표를 많이 찍었는데,"
        }
      ]
    },
    {
      "tStartMs": 556056,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "\n친구가"
        }
      ]
    },
    {
      "tStartMs": 558125,
      "dDurationMs": 2436,
      "segs": [
        {
          "utf8": "그게 너무 공격적인 거라고 말해줬어요.\n[웃음]"
        }
      ]
    },
    {
      "tStartMs": 560561,
      "dDurationMs": 2569,
      "segs": [
        {
          "utf8": "-\n저도 최근에"
        }
      ]
    },
    {
      "tStartMs": 563130,
      "dDurationMs": 2035,
      "segs": [
        {
          "utf8": "이모티콘이 이제\n노인들이 쓰는 거라고 들었는데, 드디어 저도 이모티콘을 쓰게 돼서"
        }
      ]
    },
    {
      "tStartMs": 565165,
      "dDurationMs": 3404,
      "segs": [
        {
          "utf8": "너무 기뻤어요\n."
        }
      ]
    },
    {
      "tStartMs": 568569,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "-네, 저는\n여전히"
        }
      ]
    },
    {
      "tStartMs": 570204,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "재치 있는 것들을 찾고 있는 것 같아요.  -\n응."
        }
      ]
    },
    {
      "tStartMs": 571572,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "어떤 사람들은 정말 좋아해요. 음, 뭐라고 해야 할까요?\n"
        }
      ]
    },
    {
      "tStartMs": 573307,
      "dDurationMs": 2869,
      "segs": [
        {
          "utf8": "저는\n번개 모양을"
        }
      ]
    },
    {
      "tStartMs": 576176,
      "dDurationMs": 4471,
      "segs": [
        {
          "utf8": "\n쓸 때면 신이 나요. '쾅!' 하는 느낌이랄까요.  -"
        }
      ]
    },
    {
      "tStartMs": 580647,
      "dDurationMs": 2570,
      "segs": [
        {
          "utf8": "그런데,\n"
        }
      ]
    },
    {
      "tStartMs": 583217,
      "dDurationMs": 4237,
      "segs": [
        {
          "utf8": "\n\"완다비전\"에 출연해서 제가 본 것 중"
        }
      ]
    },
    {
      "tStartMs": 587454,
      "dDurationMs": 2002,
      "segs": [
        {
          "utf8": "\n최고로 멋진"
        }
      ]
    },
    {
      "tStartMs": 589456,
      "dDurationMs": 3070,
      "segs": [
        {
          "utf8": "번개 효과를 보여준 사람이 \"\n"
        }
      ]
    },
    {
      "tStartMs": 592526,
      "dDurationMs": 1735,
      "segs": [
        {
          "utf8": "\n문자로도 그런 효과를 내본 적 있어요?\"라고 묻는 게 너무 안타까워요."
        }
      ]
    },
    {
      "tStartMs": 594261,
      "dDurationMs": 2069,
      "segs": [
        {
          "utf8": "[웃음] - 제가"
        }
      ]
    },
    {
      "tStartMs": 596330,
      "dDurationMs": 1601,
      "segs": [
        {
          "utf8": "말하려던 게 바로 이거예요\n,"
        }
      ]
    },
    {
      "tStartMs": 597931,
      "dDurationMs": 2036,
      "segs": [
        {
          "utf8": "90세 노인 얘기 말이에요\n.  \"이터니티\"를"
        }
      ]
    },
    {
      "tStartMs": 599967,
      "dDurationMs": 2135,
      "segs": [
        {
          "utf8": "\n촬영할 때 앤 미어라의 영상을 정말 많이 봤는데,"
        }
      ]
    },
    {
      "tStartMs": 602102,
      "dDurationMs": 2836,
      "segs": [
        {
          "utf8": "\n아직 다큐멘터리는 못 봤어요. 앤 미어라"
        }
      ]
    },
    {
      "tStartMs": 604938,
      "dDurationMs": 4471,
      "segs": [
        {
          "utf8": "와\n제리 스틸러의 심야 토크쇼에 푹 빠져 있었거든요."
        }
      ]
    },
    {
      "tStartMs": 609409,
      "dDurationMs": 2803,
      "segs": [
        {
          "utf8": "그리고 그 점을\n"
        }
      ]
    },
    {
      "tStartMs": 612212,
      "dDurationMs": 2870,
      "segs": [
        {
          "utf8": "\n제 캐릭터"
        }
      ]
    },
    {
      "tStartMs": 615082,
      "dDurationMs": 1268,
      "segs": [
        {
          "utf8": "와 마일스 텔러의\n캐릭터를 위한 참고점으로 활용할 수 있어서 정말 만족스러웠습니다."
        }
      ]
    },
    {
      "tStartMs": 616350,
      "dDurationMs": 1801,
      "segs": [
        {
          "utf8": "-정말 좋네요."
        }
      ]
    },
    {
      "tStartMs": 618151,
      "dDurationMs": 2303,
      "segs": [
        {
          "utf8": "음, 최대한 스포일러는 하지 않겠지만\n,"
        }
      ]
    },
    {
      "tStartMs": 620454,
      "dDurationMs": 3136,
      "segs": [
        {
          "utf8": "\n두 분의 연기를 보는 건 정말 즐거워요."
        }
      ]
    },
    {
      "tStartMs": 623590,
      "dDurationMs": 2436,
      "segs": [
        {
          "utf8": "당연히 저희는 그런 연기 스타일을 아주 잘 알고 있습니다. 특히 두 분 모두\n"
        }
      ]
    },
    {
      "tStartMs": 626026,
      "dDurationMs": 2269,
      "segs": [
        {
          "utf8": "\n젊은 몸으로 노인 역할을"
        }
      ]
    },
    {
      "tStartMs": 628295,
      "dDurationMs": 2202,
      "segs": [
        {
          "utf8": "훌륭하게 소화해내셨죠.\n정말 재밌었어요.  -네, 그건"
        }
      ]
    },
    {
      "tStartMs": 630497,
      "dDurationMs": 2302,
      "segs": [
        {
          "utf8": "\n확실히 세대를 초월하는"
        }
      ]
    },
    {
      "tStartMs": 632799,
      "dDurationMs": 3437,
      "segs": [
        {
          "utf8": "\n시청 경험이라고 생각해요."
        }
      ]
    },
    {
      "tStartMs": 636236,
      "dDurationMs": 4638,
      "segs": [
        {
          "utf8": "음, 그건\n사후 세계를 배경으로 한 영화인데, 아주"
        }
      ]
    },
    {
      "tStartMs": 640874,
      "dDurationMs": 2736,
      "segs": [
        {
          "utf8": "\n평범한 사랑 이야기예요. 65년 동안 결혼 생활을 한"
        }
      ]
    },
    {
      "tStartMs": 643610,
      "dDurationMs": 3270,
      "segs": [
        {
          "utf8": "부부의 이야기인데,\n"
        }
      ]
    },
    {
      "tStartMs": 646880,
      "dDurationMs": 1969,
      "segs": [
        {
          "utf8": "여자가\n사후 세계에 가게 되고, 거기서"
        }
      ]
    },
    {
      "tStartMs": 648849,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "\n"
        }
      ]
    },
    {
      "tStartMs": 650751,
      "dDurationMs": 2135,
      "segs": [
        {
          "utf8": "한국 전쟁에서 전사한 첫 남편이\n"
        }
      ]
    },
    {
      "tStartMs": 652886,
      "dDurationMs": 1802,
      "segs": [
        {
          "utf8": "\n67년 동안 자신을 기다리고 있었다는 사실을 알게 되는 내용이에요."
        }
      ]
    },
    {
      "tStartMs": 654688,
      "dDurationMs": 4004,
      "segs": [
        {
          "utf8": "그리고 이건... 진심이 담겨 있으면서도\n엉뚱한 코미디예요.  -지금이 바로 나오기에"
        }
      ]
    },
    {
      "tStartMs": 658692,
      "dDurationMs": 1635,
      "segs": [
        {
          "utf8": "아주 좋은 시기네요\n.  -"
        }
      ]
    },
    {
      "tStartMs": 660327,
      "dDurationMs": 1435,
      "segs": [
        {
          "utf8": "응.  -\n언제나 만나서 반가워요."
        }
      ]
    },
    {
      "tStartMs": 661762,
      "dDurationMs": 1234,
      "segs": [
        {
          "utf8": "\n와주셔서 정말 감사합니다.  -초대해 주셔서 감사합니다"
        }
      ]
    },
    {
      "tStartMs": 662996,
      "dDurationMs": 1068,
      "segs": [
        {
          "utf8": ".\n정말 감사드립니다."
        }
      ]
    },
    {
      "tStartMs": 664064,
      "dDurationMs": 1902,
      "segs": [
        {
          "utf8": "여러분,\n이분은 엘리자베스 올슨입니다.  -"
        }
      ]
    },
    {
      "tStartMs": 665966,
      "dDurationMs": 1268,
      "segs": [
        {
          "utf8": "여러분, 영화 \"이터니티\"가 추수\n"
        }
      ]
    },
    {
      "tStartMs": 667234,
      "dDurationMs": 1368,
      "segs": [
        {
          "utf8": "감사절에 전국 극장에서 개봉합니다.  잠시만 기다려 주세요\n."
        }
      ]
    }
  ]
}