  "examples": [
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "다행히도 그는 집에 있었다",
      "text": "I had the <b>luck</b> to find him at home. or By good <b>luck</b>, I found him at home."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "나는 극히 운이 좋았다",
      "text": "I had capital <b>luck</b>."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "그곳에서 그를 만난 것은 천만다행이었다",
      "text": "It was by a stroke of good <b>luck</b> that I met him there. or I found him there by pure <b>luck</b>."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "이제 운이 다한 것 같다",
      "text": "I'm afraid my <b>luck</b> has run out."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "그는 나의 행운을 기뻐해 주었다.",
      "text": "He joyed in my good <b>luck</b>."
    }
