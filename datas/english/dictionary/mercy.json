  "examples": [
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "나는 그를 가엾이 여겨 용서해 주었다.",
      "text": "I spared him out of <b>mercy</b>."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "우리는 이틀 간이나 물결 가는 데로 떠다녔다",
      "text": "We drifted about at the <b>mercy</b> of the waves[were tossed about by the waves] for two days."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "살리든 죽이든 네 마음대로 해라",
      "text": "My life is in your hands[at your <b>mercy</b>]."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "네가 안 가서 다행이다",
      "text": "It is a <b>mercy</b>[a good thing] that you did not go."
    },
    {
      "source": "동아출판 프라임 영한사전",
      "matchType": "allterm:proximity:1.000000",
      "translatedText": "그녀는 매우 자애로운 사람처럼 행동한다.",
      "text": "She reveals herself as full of <b>mercy</b>."
    }
